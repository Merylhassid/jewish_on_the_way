PORT=3001

DB_HOST=your-db-host.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASS=
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

JWT_SECRET=
JWT_EXPIRES_IN=30d

CLOUDINARY_CLOUD_NAME=
