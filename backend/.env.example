# Backend Environment Variables

## Server
PORT=3001

## Database (PostgreSQL)
DB_HOST=ep-weathered-tree-amr8w5v7-pooler.c-5.us-east-1.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASS=your_database_password
DB_SSL=true
# Optional. Defaults to false for Neon compatibility unless explicitly set.
DB_SSL_REJECT_UNAUTHORIZED=false

## JWT Authentication
JWT_SECRET=change_this_to_a_strong_secret_in_production
JWT_EXPIRES_IN=1h

## Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

## Email (SMTP) - for password reset and notifications
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

## Frontend URL - used in password reset links
APP_URL=http://localhost:3000

## CORS
# Development can leave this empty because the backend allows all origins unless NODE_ENV=production.
# Production should be a comma-separated allowlist, for example:
# CORS_ORIGINS=https://your-frontend.example,https://admin.your-frontend.example
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

## Node Environment
# Use NODE_ENV=production on the deployed server.
NODE_ENV=development
