PORT=3001

DB_HOST=your-db-host.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASS=
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

JWT_SECRET=
JWT_EXPIRES_IN=15m

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (SMTP) — for forgot password
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=

# Frontend URL (used in password reset link)
APP_URL=http://localhost:3001

NODE_ENV=development
CORS_ORIGINS=http://localhost:8081

# Smart search parser shadow mode
ANTHROPIC_API_KEY=
SMART_SEARCH_LLM_MODEL=claude-haiku-4-5-20251001
SMART_SEARCH_LLM_TIMEOUT_MS=10000
SMART_SEARCH_SHADOW_SAMPLE=0.1
SMART_SEARCH_LLM_DAILY_CAP=50
