MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=

# Frontend URL (used in password reset link)
APP_URL=http://localhost:3001

NODE_ENV=development
CORS_ORIGINS=http://localhost:8081
